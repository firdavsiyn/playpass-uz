<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules (Android 12+).
  We disable auto-backup of app data to prevent sensitive tokens
  (Supabase session, FCM token) from leaking to Google servers.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" />
        <exclude domain="database" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>
