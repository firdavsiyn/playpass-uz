{
  "rewrites": [
    { "source": "/((?!main\\.dart\\.js|flutter_bootstrap\\.js|flutter_service_worker\\.js|canvaskit|assets|icons|manifest\\.json|favicon\\.png|version\\.json).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/flutter_bootstrap.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/main.dart.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
