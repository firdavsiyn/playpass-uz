# ============================================================
# GamePass UZ — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── Rahmat.uz ─────────────────────────────────────────────
RAHMAT_API_URL=https://api.rahmat.uz
RAHMAT_API_KEY=YOUR_RAHMAT_API_KEY
RAHMAT_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── Eskiz.uz ─────────────────────────────────────────────
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=YOUR_ESKIZ_PASSWORD
ESKIZ_TOKEN=                     # Auto-filled by n8n after auth

# ── Firebase FCM ──────────────────────────────────────────
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY

# ── Yandex Maps ───────────────────────────────────────────
YANDEX_MAPS_API_KEY=YOUR_YANDEX_MAPS_KEY

# ── n8n ───────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n.railway.app/webhook
N8N_WEBHOOK_SECRET=YOUR_N8N_SECRET
